# ── SPIR Extraction Tool — Environment Configuration ──────────────────────────
# Copy this file to .env and adjust values for your environment.
# Never commit .env to version control.

# Application
APP_NAME=SPIR Extraction Tool
APP_VERSION=9.0.0
DEBUG=false
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# File handling
MAX_FILE_SIZE_MB=100
UPLOAD_DIR=/tmp/spir_uploads
RESULT_TTL_SECONDS=3600      # 1 hour — how long extracted files stay in Redis

# Redis (broker + result store)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER=redis://localhost:6379/0
CELERY_BACKEND=redis://localhost:6379/1

# CORS — set to your frontend domain in production
# ALLOWED_ORIGINS=["https://spir.yourcompany.com"]
ALLOWED_ORIGINS=["*"]

# Preview
PREVIEW_ROW_COUNT=12
